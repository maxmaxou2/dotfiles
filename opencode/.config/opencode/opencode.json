{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-gemini-auth@latest",
    "opencode-claude-auth",
    "@tarquinen/opencode-dcp@latest",
    "context-mode",
    "./plugins/agentmemory-capture.ts"
  ],
  "permission": "allow",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM (Proxy)",
      "options": {
        "baseURL": "http://localhost:4000/v1",
        "apiKey": "{env:LITELLM_MASTER_KEY}"
      },
      "models": {
        "gemini-3-pro": { "name": "Gemini 3 Pro Preview" },
        "copilot-sonnet": { "name": "Copilot Claude Sonnet 4.6" },
        "copilot-opus": { "name": "Copilot Claude Opus 4.8" },
        "copilot-haiku": { "name": "Copilot Claude Haiku 4.5" },
        "deepseek-v4-flash": { "name": "Opencode Go (DeepSeek V4 Flash)" }
      }
    }
  },
  "compaction": {
    "auto": false,
    "prune": true,
    "reserved": 10000
  },
  "mcp": {
    "agentmemory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@agentmemory/mcp"
      ],
      "environment": {
        "AGENTMEMORY_URL": "http://localhost:3111"
      }
    },
    "code-review-graph": {
      "type": "local",
      "command": [
        "/Users/maxence/.local/bin/code-review-graph",
        "mcp"
      ]
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".pnpm-store/**",
      ".bun/**",
      "**/__pycache__/**",
      "**/*.py[cod]",
      "**/.pytest_cache/**",
      "**/.mypy_cache/**",
      "**/.ruff_cache/**",
      ".venv/**",
      "venv/**",
      ".next/**",
      ".nuxt/**",
      "dist/**",
      "build/**",
      "out/**",
      ".turbo/**",
      "target/**",
      "CMakeFiles/**",
      "**/*.o",
      "**/*.a",
      "coverage/**",
      ".nyc_output/**",
      "pgdata/**",
      "redis-data/**",
      "meilisearch-data/**",
      "minio-data/**",
      "logs/**",
      "**/*.log",
      ".git/**",
      "**/*.min.js",
      "**/*.min.css",
      "**/*.map"
    ]
  }
}
