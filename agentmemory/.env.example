# =============================================================================
# agentmemory configuration — dotfiles template
# =============================================================================
#
# Copied to ~/.agentmemory/.env on `make agentmemory` if absent.
# Real values live there (gitignored). NEVER commit a populated .env.
#
# Full reference: https://github.com/rohitg00/agentmemory/blob/main/.env.example
# Below = only the keys this dotfiles setup uses (LiteLLM -> Vertex stack).

# --- LLM via LiteLLM proxy -> Vertex gemini-2.5-flash ---
# OPENAI_API_KEY must match the master_key in ~/.config/litellm/config.yaml
OPENAI_API_KEY=sk-litellm-REPLACE_WITH_LITELLM_MASTER_KEY
OPENAI_BASE_URL=http://localhost:4000
OPENAI_MODEL=gemini-flash
MAX_TOKENS=1024

# --- Embeddings via LiteLLM -> Vertex gemini-embedding-2 (768-dim, MRL) ---
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=vertex-embed
OPENAI_EMBEDDING_DIMENSIONS=768

# --- Behaviour ---
AGENTMEMORY_AUTO_COMPRESS=true       # LLM-compress every observation batch
AGENTMEMORY_INJECT_CONTEXT=true      # Inject recalled memories into prompts
CONSOLIDATION_ENABLED=true           # 4-tier consolidation pipeline
GRAPH_EXTRACTION_ENABLED=true        # Concept-graph edges on remember

# --- MCP shim: trust the daemon, never standalone-fallback ---
AGENTMEMORY_URL=http://localhost:3111
AGENTMEMORY_FORCE_PROXY=1

# --- Recovery toggle (uncomment ONCE if embedding-dim mismatch blocks startup) ---
# AGENTMEMORY_DROP_STALE_INDEX=true
