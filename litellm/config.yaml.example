# LiteLLM proxy → Vertex AI (Gemini) for agentmemory LLM + embeddings.
#
# Copy to ~/.config/litellm/config.yaml and fill the two secrets:
#   1. vertex_credentials → path to your Vertex service-account JSON
#   2. master_key        → any random string (becomes agentmemory's OPENAI_API_KEY)
#
#   cp config.yaml.example ~/.config/litellm/config.yaml
#   # then edit the two values below, chmod 600 ~/.config/litellm/config.yaml
#
# The real config.yaml + the SA JSON are SECRETS — never commit them
# (.gitignore blocks litellm/config.yaml and *-sa.json).

model_list:
  # LLM — observation compression (gemini-2.5-flash, regional)
  - model_name: gemini-flash
    litellm_params:
      model: vertex_ai/gemini-2.5-flash
      vertex_project: jayn-dev               # GCP project id
      vertex_location: europe-west4          # region (SA auth supports regional endpoints)
      vertex_credentials: /Users/maxence/.config/litellm/vertex-sa.json
      reasoning_effort: disable              # no thinking — compression doesn't need it (saves tokens/latency)
  # LLM — architect-gemini (Gemini 3 Pro Preview, global endpoint)
  - model_name: gemini-3-pro
    litellm_params:
      model: vertex_ai/gemini-3.1-pro-preview
      vertex_project: jayn-dev
      vertex_location: global                # preview model: global endpoint
      vertex_credentials: /Users/maxence/.config/litellm/vertex-sa.json
  # Embeddings — gemini-embedding-2 (GA, top MTEB). NOTE: global endpoint only,
  # 404s on regional like europe-west4. 768-dim (MRL truncation, no quality loss).
  - model_name: vertex-embed
    litellm_params:
      model: vertex_ai/gemini-embedding-2
      vertex_project: jayn-dev
      vertex_location: global                # embedding-2 is global-endpoint only
      vertex_credentials: /Users/maxence/.config/litellm/vertex-sa.json
      dimensions: 768
litellm_settings:
  drop_params: true                          # tolerate OpenAI params Vertex doesn't accept
general_settings:
  master_key: sk-litellm-REPLACE_WITH_RANDOM # = agentmemory OPENAI_API_KEY (loopback-only)
