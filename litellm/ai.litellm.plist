<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.litellm</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/maxence/.local/bin/litellm</string>
    <string>--config</string>
    <string>/Users/maxence/.config/litellm/config.yaml</string>
    <string>--port</string>
    <string>4000</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/Users/maxence/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>HOME</key>
    <string>/Users/maxence</string>
  </dict>

  <key>WorkingDirectory</key>
  <string>/Users/maxence/.config/litellm</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/maxence/.config/litellm/litellm.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/maxence/.config/litellm/litellm.log</string>

  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
