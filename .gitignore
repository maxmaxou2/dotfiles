# --- Neovim Runtime & State ---
*.swp
*.swo
undo/
*.un~
shada/

# --- Language Servers & Tools ---
lua/mason/
bin/

# --- Log Files ---
*.log

# --- OS Specific ---
.DS_Store

**/automatic_backups/*.json
**/*.bak

# --- Architect planning ephemera ---
opencode/.config/opencode/misc/coding-team/

# --- Secrets (never commit) ---
litellm/config.yaml          # real litellm config holds master_key (use config.yaml.example)
agentmemory/.env             # real agentmemory env holds litellm key (use .env.example)
**/*-sa.json                 # GCP service-account keys
**/vertex-sa.json
**/github_copilot/           # Copilot device-flow creds (access-token + api-key.json)
litellm/.config/litellm/.env # real litellm env: master_key, copilot token, db url (use .env.example)

misc/
